# Admin panel password (required in production).
# Pick a strong password; you log in to /admin with it.
ADMIN_PASSWORD=

# Vercel Blob read/write token (created automatically when you connect a Blob
# store in the Vercel dashboard). Not needed for local development — content is
# stored in the .data folder instead.
BLOB_READ_WRITE_TOKEN=

# Full public URL of the site (for SEO and the sitemap),
# e.g. https://pooyachoob.ir
NEXT_PUBLIC_SITE_URL=
